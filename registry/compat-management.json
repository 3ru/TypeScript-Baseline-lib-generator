            "id": "generator-function-partial-model",
            "category": "ts_settled_limitation",
            "delivery": "defer-upstream",
            "upstreamState": "settled",
            "reason": "TypeScript ships GeneratorFunction names in lib files, but actual generator function values are not modeled as GeneratorFunction under the current checker and declaration-emit architecture.",
            "sourceUrls": [
                "https://github.com/microsoft/TypeScript/issues/45146",
                "https://github.com/microsoft/TypeScript/issues/3841",
                "https://github.com/microsoft/TypeScript/issues/44883",
                "https://github.com/microsoft/TypeScript/issues/56645",
                "https://github.com/microsoft/TypeScript/pull/56646"
            ],
            "externalAction": {
                "kind": "watch-existing",
                "repo": "microsoft/TypeScript",
                "targetUrl": "https://github.com/microsoft/TypeScript/issues/45146",
                "note": "Re-evaluate only if lib/checker connectivity changes or linked issues advance."
            },
            "compatKeys": [
                "javascript.builtins.GeneratorFunction",
                "javascript.builtins.GeneratorFunction.GeneratorFunction"
            ]
        },
