            "scope": "static",
            "memberNames": [
                "lastMatch",
                "$&"
            ]
        },
        "javascript.builtins.RegExp.lastParen": {
            "scope": "static",
            "memberNames": [
                "lastParen",
                "$+"
            ]
        },
        "javascript.builtins.RegExp.leftContext": {
            "scope": "static",
            "memberNames": [
                "leftContext",
                "$`"
            ]
        },
        "javascript.builtins.RegExp.n": {
            "scope": "static",
            "memberNames": [
                "$1",
                "$2",
                "$3",
                "$4",
                "$5",
                "$6",
                "$7",
                "$8",
                "$9"
            ]
        },
