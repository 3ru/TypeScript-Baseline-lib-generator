{
    "compilerOptions": {
        "target": "ES2023",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "lib": [
            "ES2023"
        ],
        "types": [
            "node"
        ],
        "allowJs": true,
        "checkJs": true,
        "strict": true,
        "noEmit": true,
        "noImplicitOverride": true,
        "noFallthroughCasesInSwitch": true,
        "useUnknownInCatchVariables": true,
        "resolveJsonModule": true,
        "skipLibCheck": true
    },
    "include": [
        "deploy/**/*.mjs",
        "lib/**/*.mjs",
        "scripts/**/*.mjs",
        "test/**/*.mjs"
    ],
    "exclude": [
        "node_modules",
        ".tmp",
        "generated",
        "fixtures"
    ]
}
